# Azure AI Foundry Project Endpoint
FOUNDRY_PROJECT_ENDPOINT=https://app-insights-foundry-resource.services.ai.azure.com/api/projects/app-insights-foundry

# Azure OpenAI Endpoint
AZURE_OPENAI_ENDPOINT=https://app-insights-foundry-resource.openai.azure.com/openai/v1

# Deployed model name
FOUNDRY_MODEL_NAME=gpt-5.4

# Application Insights Connection String
# Find this in Azure Portal > App Insights resource > Overview > Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=your-application-insights-connection-string-here
